# ========================================
# Database (PostgreSQL)
# ========================================
DATABASE_URL=postgresql://user:password@localhost:5432/visvas
PAYLOAD_SECRET=your_strong_random_secret_32_bytes_minimum

# ========================================
# Email (Zoho Zeptomail)
# ========================================
ZOHO_ZEPTOMAIL_TOKEN=your_zoho_zeptomail_api_token_here
ZOHO_ZEPTOMAIL_SENDER_EMAIL=noreply@yourdomain.com
ZOHO_ZEPTOMAIL_SENDER_NAME=Visvas Properties

# Admin notification recipient (receives all form submissions)
ADMIN_EMAIL=admin@yourdomain.com

# Business contact information (public-facing)
NEXT_PUBLIC_BUSINESS_EMAIL=enquiry@yourdomain.com
NEXT_PUBLIC_BUSINESS_PHONE=+91-94038-93898
NEXT_PUBLIC_CONTACT_EMAIL=contact@yourdomain.com

# ========================================
# Google Sheets (optional)
# ========================================
GOOGLE_SHEETS_API_KEY=your_google_sheets_api_key_here
GOOGLE_SHEETS_SPREADSHEET_ID=your_google_sheets_spreadsheet_id_here

# ========================================
# Cloudflare R2 (Media Storage)
# ========================================
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY=your_r2_access_key_id
R2_SECRET_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=your_r2_bucket_name

# ========================================
# Database Storage
# ========================================
# Types: json (default), sqlite, both
DATABASE_TYPE=json
DATABASE_DIR=data

# ========================================
# Analytics (optional - client-side only)
# ========================================
NEXT_PUBLIC_SITE_URL=https://www.yourdomain.com
NEXT_PUBLIC_GADS_ID=your_google_ads_conversion_id_here

# ========================================
# Runtime
# ========================================
NODE_ENV=development
